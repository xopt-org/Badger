FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    xvfb \
    xauth \
    libgl1 \
    libglib2.0-0 \
    libfontconfig1 \
    libxkbcommon0 \
    libdbus-1-3 \
    libegl1 \
    libxcb-cursor0 \
    libxcb-icccm4 \
    libxcb-keysyms1 \
    libxcb-shape0 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pyqt5 pyqtgraph

COPY smoketest.py /smoketest.py

CMD ["xvfb-run", "--auto-servernum", "python", "/smoketest.py"]
